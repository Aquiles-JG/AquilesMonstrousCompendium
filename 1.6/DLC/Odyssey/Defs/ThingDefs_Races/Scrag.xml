<?xml version="1.0" encoding="utf-8" ?>
<Defs>

 <ThingDef ParentName="AnimalThingBase">
    <defName>Aq_SaltwaterScrag</defName>
    <label>scrag</label>
    <description>A scrag is a marine troll, a gilled form of the land species that can be found in large bodies of water. Smaller than the common troll, a scrag can regenerate as well, but only when immersed in water.</description>
    <statBases>
      <MoveSpeed>3.4</MoveSpeed>
      <Flammability>1.4</Flammability>
      <MarketValue>450</MarketValue>
      <ArmorRating_Blunt>0.4</ArmorRating_Blunt>
	  <ArmorRating_Sharp>0.5</ArmorRating_Sharp>
      <ComfyTemperatureMin>-40</ComfyTemperatureMin>
      <FilthRate>9</FilthRate>
      <Wildness>0.90</Wildness>
    </statBases>
    <uiIconScale>1.3</uiIconScale>
    <comps>
    	<li Class="VEF.AnimalBehaviours.CompProperties_Regeneration">
				<rateInTicks>60</rateInTicks>
				<needsWater>true</needsWater>
		</li>
		<li Class="VEF.AnimalBehaviours.CompProperties_Infecter">
				<infectionChance>30</infectionChance>		
		</li>
	</comps>
    <tools>
	  <!-- hands -->
	  <li>
        <label>left claw</label>
        <capacities>
          <li>Aq_InfectiousClaws</li>
        </capacities>
        <power>11</power>
        <cooldownTime>1.5</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftClaws</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>12</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>right claw</label>
        <capacities>
          <li>Aq_InfectiousClaws</li>
        </capacities>
        <power>11</power>
        <cooldownTime>1.5</cooldownTime>
        <linkedBodyPartsGroup>FrontRightClaws</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>12</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
	  <!-- head -->
      <li>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>14</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.7</chanceFactor>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>12</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>8</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <body>Aq_ScragBody</body>
      <herdAnimal>false</herdAnimal>
      <predator>true</predator>
      <baseBodySize>2</baseBodySize>
      <baseHungerRate>0.425</baseHungerRate>
      <baseHealthScale>2.25</baseHealthScale>
      <foodType>Corpse,CarnivoreAnimal,OvivoreAnimal</foodType>
      <trainability>Advanced</trainability>
      <leatherDef>Leather_Aq_Scrag</leatherDef>
      <gestationPeriodDays>20</gestationPeriodDays>
      <waterSeeker>true</waterSeeker>
      <waterCellCost>1</waterCellCost>
      <manhunterOnTameFailChance>0.25</manhunterOnTameFailChance>
      <manhunterOnDamageChance>1.0</manhunterOnDamageChance>
      <canFishForFood>false</canFishForFood>   <!-- To force to predate on land-->
      <specificMeatDef MayRequire="Ludeon.Rimworld.Anomaly">Meat_Twisted</specificMeatDef>
      <meatLabel>scrag meat</meatLabel>
      <specialTrainables>
        <li MayRequire="Ludeon.RimWorld.Odyssey">AttackTarget</li>
      </specialTrainables>
      <lifeExpectancy>13</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.25</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.5</minAge>
          <soundWounded>Aq_Scrag_Wounded</soundWounded>
          <soundDeath>Aq_Scrag_Death</soundDeath>
          <soundCall>Aq_Scrag_Call</soundCall>
          <soundAngry>Aq_Scrag_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundEating>PredatorLarge_Eat</soundEating>
      <soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
    </race>
    <tradeTags>
      <li>AnimalAlpha</li>
    </tradeTags>
    <butcherProducts MayRequire="Aquiles.Elves">
      <Aq_TrollBlood>1</Aq_TrollBlood>
    </butcherProducts>
  </ThingDef>
  
