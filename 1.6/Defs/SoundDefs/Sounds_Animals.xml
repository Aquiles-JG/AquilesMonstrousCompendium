  <!-- Scrags and trolls share the same sounds-->
  <SoundDef>
    <defName>Aq_Scrag_Call</defName>
    <context>MapOnly</context>
    <subSounds>
      <li>
        <grains>
          <li Class="AudioGrain_Clip">
            <!-- Bull-SoundBible.com-1252561191 -->
            <clipPath>Scrag/Scrag_Calls</clipPath>
          </li>
        </grains>
        <volumeRange>35.42672~34.7734</volumeRange>
        <pitchRange>0.9770588~1.137647</pitchRange>
        <distRange>0~50.40025</distRange>
        <sustainLoop>False</sustainLoop>
      </li>
    </subSounds>
  </SoundDef>
